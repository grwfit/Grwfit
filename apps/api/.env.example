# Copy from root .env.example and add API-specific vars
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000

DATABASE_URL="postgresql://postgres:password@localhost:5432/grwfit"
DIRECT_URL="postgresql://postgres:password@localhost:5432/grwfit"

JWT_ACCESS_SECRET=dev-access-secret-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod
JWT_PLATFORM_SECRET=dev-platform-secret-change-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

REDIS_URL=redis://localhost:6379

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

WHATSAPP_BSP=gupshup
GUPSHUP_API_KEY=
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
